{
  "meta": {
    "version": "1",
    "style_id": "glass-news-report",
    "style_name": "玻璃质感新闻风",
    "source": "preset",
    "reason": "销售周报更适合清晰、专业、信息分层强的资讯卡片风格"
  },
  "colors": {
    "page_background": "#0d1321",
    "page_gradient": "linear-gradient(165deg, #0d1321 0%, #1a1f3c 35%, #242444 70%, #1e2a4a 100%)",
    "surface": "rgba(255, 255, 255, 0.06)",
    "surface_border": "rgba(255, 255, 255, 0.12)",
    "primary": "#ffffff",
    "secondary": "#60a5fa",
    "accent": "#f59e0b",
    "accent_soft": "rgba(245, 158, 11, 0.15)",
    "text_primary": "#f8fafc",
    "text_secondary": "#cbd5e1",
    "text_muted": "#94a3b8"
  },
  "fonts": {
    "title_family": "'Noto Sans SC', sans-serif",
    "body_family": "'Noto Sans SC', sans-serif",
    "mono_family": "'JetBrains Mono', 'DM Mono', monospace",
    "title_size": "56px",
    "heading_size": "36px",
    "body_size": "30px",
    "label_size": "24px",
    "title_weight": 800,
    "body_weight": 400
  },
  "layout": {
    "canvas_width": "1080px",
    "min_height": "100vh",
    "page_padding": "40px",
    "container_width": "1000px",
    "section_gap": "28px",
    "card_padding": "36px",
    "card_radius": "28px"
  },
  "effects": {
    "shadow": "0 18px 48px rgba(15, 23, 42, 0.28)",
    "glow": "0 0 20px rgba(96, 165, 250, 0.16)",
    "noise": true
  }
}
